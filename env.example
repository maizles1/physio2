# ============================================
# Environment Variables Template
# העתק קובץ זה ל-.env.local והחלף את הערכים
# ============================================

# ============================================
# Security - API Authentication
# ============================================
# API Secret Key for protecting API routes (production only)
# Generate a strong random string (e.g., using: openssl rand -hex 32)
API_SECRET_KEY=your-secret-api-key-here

# ============================================
# Google My Business / Google Places API
# ============================================
# Place ID of your Google My Business listing
NEXT_PUBLIC_GOOGLE_PLACE_ID=ChIJ...

# Google Maps API Key
GOOGLE_MAPS_API_KEY=AIza...

# ============================================
# YouTube Videos
# ============================================
VIDEO_1_URL=https://www.youtube.com/watch?v=VIDEO_ID
VIDEO_2_URL=https://www.youtube.com/watch?v=VIDEO_ID
VIDEO_3_URL=https://www.youtube.com/watch?v=VIDEO_ID

# ============================================
# Contact Form - Email Service (Web3Forms)
# ============================================
# Web3Forms Access Key for sending contact form emails.
# Get your access key from: https://web3forms.com
# Sign up for free account at: https://web3forms.com
# Free tier: 250 submissions/month
# Note: This is used server-side only (in API route), so no NEXT_PUBLIC_ prefix needed.
# Also used as an OPTIONAL backup channel by /api/lead (Meuhedet landing page form):
#   - If set, each /api/lead submission is forwarded to Web3Forms in addition to
#     being saved to Vercel Blob.
#   - If not set, submissions are saved only to Blob / local file.
WEB3FORMS_ACCESS_KEY=your_access_key_here

# ============================================
# Newsletter & Leads - Email notifications (Optional)
# ============================================
# Resend API Key. Used by two flows:
#   1. /api/newsletter — sends a welcome email to new subscribers.
#   2. /api/lead       — sends a notification email to the clinic for each
#                        Meuhedet landing-page lead (subject "ליד חדש מ-/meuhedet").
# Get your key from: https://resend.com
# If not set, the request still succeeds — only the email step is skipped.
RESEND_API_KEY=re_your_key_here
# Optional: From address for newsletter welcome emails (must be verified in Resend).
# NEWSLETTER_FROM=פיזיותרפיה.פלוס <noreply@physio-plus.co.il>
# Optional: From address used by /api/lead notifications. Falls back to
# NEWSLETTER_FROM, then to Resend's onboarding sender.
# LEADS_FROM=פיזיותרפיה.פלוס <noreply@physio-plus.co.il>
# Optional: Override the recipient for lead notifications.
# Defaults to amphysiotherapy1@gmail.com if unset.
# LEADS_TO=amphysiotherapy1@gmail.com

# ============================================
# SEO Monitoring & Email Reports (Optional)
# ============================================
SEO_REPORT_EMAIL_FROM=noreply@physio-plus.co.il
SEO_REPORT_EMAIL_TO=your-email@example.com
GOOGLE_PAGESPEED_API_KEY=your-api-key-here

# ============================================
# Image Generation (Optional)
# ============================================
REPLICATE_API_TOKEN=r8_your_token_here
OPENAI_API_KEY=sk-your_key_here
UNSPLASH_ACCESS_KEY=your_access_key_here

# ============================================
# CORS Configuration (Optional)
# ============================================
ALLOWED_ORIGINS=https://physio-plus.co.il,https://www.physio-plus.co.il

# ============================================
# GitHub Actions — Daily site health
# ============================================
# Workflow: .github/workflows/daily-site-health.yml
# No secrets required: failures open a GitHub Issue, and GitHub emails you
# automatically (Settings → Notifications → Actions: failed workflows only).
# Install the GitHub Mobile App for push notifications on the phone.


